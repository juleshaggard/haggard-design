---
import logoUrl from '../../Logo.svg?url';
import { withBasePath } from '../lib/paths';
import { siteName } from '../lib/seo';

interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;

const navLinks = [
  { href: '/pricing', label: 'Pricing' },
  { href: '/all-work', label: 'Work' },
  { href: '/about', label: 'About' },
  { href: 'mailto:hello@haggard.design', label: 'Contact', ariaLabel: `Email ${siteName}` },
];

const bookingHref = 'https://calendar.app.google/GG164fyHe4HyD5V49';
const isCurrent = (href: string) => href !== 'mailto:hello@haggard.design' && currentPath === href;
const hrefFor = (href: string) => withBasePath(href);
---

<nav class="nav" aria-label="Primary">
  <span class="nav-hover-glow" aria-hidden="true"></span>
  <a
    href={hrefFor('/')}
    class:list={['logo', 'w-inline-block', { 'w--current': currentPath === '/' }]}
    aria-current={currentPath === '/' ? 'page' : undefined}
    aria-label={`${siteName} home`}
  >
    <img class="navbar-logo" src={logoUrl} alt="" aria-hidden="true" decoding="async" />
    <span class="logo-wordmark">{siteName}</span>
  </a>
  <div class="div-block-29">
    {
      navLinks.map((link) => (
        <a
          href={hrefFor(link.href)}
          class:list={['navlink', { 'w--current': isCurrent(link.href) }]}
          aria-current={isCurrent(link.href) ? 'page' : undefined}
          aria-label={link.ariaLabel}
        >
          <span class="navlink-label">{link.label}</span>
        </a>
      ))
    }
    <a class="ctalink nav-cta" href={bookingHref} aria-label={`Book a call with ${siteName}`}>
      <svg class="nav-cta-icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
        <rect x="3" y="4" width="18" height="18" rx="2"></rect>
        <path d="M8 2v4"></path>
        <path d="M16 2v4"></path>
        <path d="M3 10h18"></path>
        <circle cx="17.75" cy="17.75" r="2.75"></circle>
        <path d="M17.75 16.35v2.8"></path>
        <path d="M16.35 17.75h2.8"></path>
      </svg>
    </a>
  </div>
</nav>
